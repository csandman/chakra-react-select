{
  "ignorePatterns": ["codemod/tests/fixtures/"],
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "sortImports": {
    "customGroups": [
      {
        "groupName": "react",
        "elementNamePattern": ["react"]
      },
      {
        "groupName": "chakra-react",
        "elementNamePattern": ["@chakra-ui/react"]
      },
      {
        "groupName": "chakra",
        "elementNamePattern": ["@chakra-ui/**"]
      }
    ],
    "groups": [
      "react",
      "chakra-react",
      "chakra",
      ["builtin", "external"],
      ["parent", "sibling", "index"],
      "unknown"
    ],
    "newlinesBetween": false,
    "ignoreCase": false
  },
  "sortPackageJson": true
}
