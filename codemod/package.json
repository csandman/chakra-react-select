{
  "name": "crs-codemod",
  "version": "1.0.3",
  "description": "A set of codemods for chakra-react-select",
  "license": "MIT",
  "author": "Chris Sandvik <chris.sandvik@gmail.com>",
  "repository": {
    "type": "git",
    "url": "csandman/chakra-react-select",
    "directory": "codemod"
  },
  "bin": "./bin/crs-codemod.js",
  "files": [
    "bin/*.js",
    "transforms/*.js"
  ],
  "type": "module",
  "scripts": {
    "prebuild": "rimraf bin/*.{d.ts,js} transforms/*.{d.ts,js}",
    "build": "tsc -d -p tsconfig.json",
    "dev": "tsc -d -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:update": "vitest run -u",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "execa": "^9.6.1",
    "globby": "^16.2.0",
    "inquirer": "^13.4.3",
    "is-git-clean": "^1.1.0",
    "jscodeshift": "^17.3.0",
    "meow": "^14.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/is-git-clean": "^1.1.2",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^24.12.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
